# Environment Variables Template
# Copy this file to .env and fill in your values for local development

# Django Settings
SECRET_KEY=your-secret-key-here-generate-a-new-one
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost,10.0.2.2

# Database (leave empty for local SQLite)
# For production, this will be automatically set by Railway/Render
DATABASE_URL=

# Optional: Set this to your remote server URL when deployed
# Example: https://your-app.up.railway.app
BACKEND_URL=
